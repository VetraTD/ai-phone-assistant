# Required: Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Required: Full public URL of your server (e.g. https://your-ngrok-id.ngrok.io) - Twilio uses this for webhook action/redirect URLs
BASE_URL=

# Required when Twilio signature validation is enabled (see below)
TWILIO_AUTH_TOKEN=

# Set to false to disable Twilio webhook signature validation (e.g. for local testing without signed requests)
# Default: validation enabled. Use false only in dev.
TWILIO_VALIDATE_SIGNATURE=

# Supabase (optional — DB persistence disabled if missing)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Timezone for date/time awareness in AI responses (default: America/Chicago)
TIMEZONE=America/Chicago

# Phone number (E.164) to dial when caller asks for a real person (optional — transfer disabled if missing)
TRANSFER_NUMBER=

# Maximum call duration in minutes before automatic hangup (default: 30)
CALL_MAX_DURATION_MINUTES=30

# Sentry DSN for error reporting (optional — disabled if missing)
SENTRY_DSN=

# Notifications (optional — set NOTIFICATIONS_ENABLED=true to enable email/SMS alerts)
NOTIFICATIONS_ENABLED=false
# SMTP for email (e.g. Gmail: enable 2-Step Verification, then create an App Password at myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=
SMTP_FROM_EMAIL=
# Twilio SMS: use same account as voice; set TWILIO_SMS_FROM to a number that can send SMS
TWILIO_ACCOUNT_SID=
TWILIO_SMS_FROM=

# CORS — comma-separated origins for dashboard (e.g. http://localhost:5173,https://app.yourdomain.com)
CORS_ORIGIN=

# Athenahealth — two app options (set the one(s) you use)
# Preview: https://api.preview.platform.athenahealth.com | Production: https://api.platform.athenahealth.com
# Platform app: for most clinics (your athena developer portal). Used when integration.config.use_ecc_app is not true.
ATHENA_CLIENT_ID=
ATHENA_CLIENT_SECRET=
ATHENA_API_BASE=https://api.preview.platform.athenahealth.com
ATHENA_TOKEN_URL=https://api.preview.platform.athenahealth.com/oauth2/v1/token
# ECC app: for ECC only (app in ECC's internal developer portal). Used when integration.config.use_ecc_app is true.
ECC_ATHENA_CLIENT_ID=
ECC_ATHENA_CLIENT_SECRET=
ECC_ATHENA_API_BASE=https://api.preview.platform.athenahealth.com
ECC_ATHENA_TOKEN_URL=https://api.preview.platform.athenahealth.com/oauth2/v1/token
